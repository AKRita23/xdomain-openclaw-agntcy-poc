# === AGNTCY Identity Service ===
AGNTCY_IDENTITY_SERVICE_URL=http://localhost:8080
AGNTCY_ISSUER_DID=did:web:example.com:issuer

# === Auth0 (Agent Identity — client_credentials) ===
AUTH0_DOMAIN=dev-agentex-xdomain.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
# Optional: fetch client secret from AWS Secrets Manager
# AUTH0_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:openclaw-auth0-creds

# === Okta (RFC 8693 Token Exchange) ===
OKTA_DOMAIN=dev-XXXXXXXX.okta.com
OKTA_AUTH_SERVER_ID=default

# === Agent Identity ===
AGENT_ID=openclaw-agent-001
DELEGATING_USER=sarah@example.com

# === Official MCP Server URLs ===
# These point to the first-party MCP servers hosted by each provider.
# Leave empty to run in stub mode (no live MCP connections).
SALESFORCE_MCP_URL=
GCAL_MCP_URL=
SLACK_MCP_URL=

# === Salesforce OAuth (for MCP server auth) ===
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com

# === Google OAuth (for MCP server auth) ===
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Slack OAuth (for MCP server auth) ===
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
